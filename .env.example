# AirlineCareerAgent environment example
# Copy this file to .env and edit the values locally.
# Do not commit your real .env file to GitHub.

# General project settings
PROJECT_NAME=AirlineCareerAgent
ENVIRONMENT=development

# Browser automation settings
# Use false to display the browser during local runs.
HEADLESS=false

# Slow down browser actions in milliseconds.
# Useful for debugging browser automation.
BROWSER_SLOW_MO_MS=500

# Job search settings
# Maximum number of jobs to collect per company during controlled runs.
MAX_JOBS_PER_COMPANY=10

# Comma-separated keywords for role filtering.
ROLE_KEYWORDS=qa automation,software qa,test automation,python,selenium,playwright

# Comma-separated airline and travel-tech domain keywords.
DOMAIN_KEYWORDS=airline,travel,aviation,fares,ticketing,pricing,revenue management,gds,ndc

# Data output settings
OUTPUT_FOLDER=data
OUTPUT_FORMAT=csv

# Future AI settings
# Leave empty until AI functionality is added.
# Never commit real API keys.
OPENAI_API_KEY=